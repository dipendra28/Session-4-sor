<?xml version='1.0'?>

<robot name="erc_bot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:include filename="$(find erc_gazebo_sensors)/urdf/erc_bot.gazebo" />
  <xacro:include filename="$(find erc_gazebo_sensors)/urdf/materials.xacro" />

  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="base_footprint"/>
    <child link="base_link" />
  </joint>

  <link name="base_link">
    <inertial>
      <mass value="15.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0625" ixy="0" ixz="0"
               iyy="0.2125" iyz="0"
               izz="0.25"/>
    </inertial>

    <collision name="base_collision">
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <geometry>
        <box size="0.4 0.2 0.1"/>
      </geometry>
    </collision>

    <visual name="base_link_visual">
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <geometry>
        <box size="0.4 0.2 0.1"/>
      </geometry>
      <material name="orange"/>
    </visual>
  </link>

  <!-- CAMERA -->
  <joint type="fixed" name="camera_joint">
    <origin xyz="0.225 0 0.075" rpy="0 0 0"/>
    <child link="camera_link"/>
    <parent link="base_link"/>
  </joint>

  <link name="camera_link">
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="1e-6" ixy="0" ixz="0"
               iyy="1e-6" iyz="0"
               izz="1e-6"/>
    </inertial>

    <collision name="camera_collision">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.03 0.03"/>
      </geometry>
    </collision>

    <visual name="camera_link_visual">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.03 0.03"/>
      </geometry>
    </visual>
  </link>

  <joint type="fixed" name="camera_optical_joint">
    <origin xyz="0 0 0" rpy="-1.5707 0 -1.5707"/>
    <child link="camera_link_optical"/>
    <parent link="camera_link"/>
  </joint>

  <link name="camera_link_optical"/>

  <!-- FRONT LEFT WHEEL -->
  <joint name="front_left_wheel_joint" type="continuous">
    <origin xyz="0.15 0.15 0.1" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <axis xyz="0 1 0"/>
    <limit effort="100" velocity="10"/>
    <dynamics damping="1.0" friction="1.0"/>
  </joint>

  <link name="front_left_wheel">
    <inertial>
      <mass value="5.0"/>
      <origin xyz="0 0 0" rpy="0 1.5707 1.5707"/>
      <inertia ixx="0.014" ixy="0" ixz="0"
               iyy="0.014" iyz="0"
               izz="0.025"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.5707 1.5707"/>
      <geometry><cylinder radius="0.1" length="0.05"/></geometry>
    </collision>
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5707 1.5707"/>
      <geometry><cylinder radius="0.1" length="0.05"/></geometry>
      <material name="green"/>
    </visual>
  </link>

  <!-- FRONT RIGHT WHEEL -->
  <joint name="front_right_wheel_joint" type="continuous">
    <origin xyz="0.15 -0.15 0.1" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <axis xyz="0 1 0"/>
    <limit effort="100" velocity="10"/>
    <dynamics damping="1.0" friction="1.0"/>
  </joint>

  <link name="front_right_wheel">
    <inertial>
      <mass value="5.0"/>
      <origin xyz="0 0 0" rpy="0 1.5707 1.5707"/>
      <inertia ixx="0.014" ixy="0" ixz="0"
               iyy="0.014" iyz="0"
               izz="0.025"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.5707 1.5707"/>
      <geometry><cylinder radius="0.1" length="0.05"/></geometry>
    </collision>
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5707 1.5707"/>
      <geometry><cylinder radius="0.1" length="0.05"/></geometry>
      <material name="green"/>
    </visual>
  </link>

  <!-- REAR LEFT WHEEL -->
  <joint name="rear_left_wheel_joint" type="continuous">
    <origin xyz="-0.08 0.15 0.1" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="rear_left_wheel"/>
    <axis xyz="0 1 0"/>
    <limit effort="100" velocity="10"/>
    <dynamics damping="1.0" friction="1.0"/>
  </joint>

  <link name="rear_left_wheel">
    <inertial>
      <mass value="5.0"/>
      <origin xyz="0 0 0" rpy="0 1.5707 1.5707"/>
      <inertia ixx="0.014" ixy="0" ixz="0"
               iyy="0.014" iyz="0"
               izz="0.025"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.5707 1.5707"/>
      <geometry><cylinder radius="0.1" length="0.05"/></geometry>
    </collision>
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5707 1.5707"/>
      <geometry><cylinder radius="0.1" length="0.05"/></geometry>
      <material name="green"/>
    </visual>
  </link>

  <!-- REAR RIGHT WHEEL -->
  <joint name="rear_right_wheel_joint" type="continuous">
    <origin xyz="-0.08 -0.15 0.1" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="rear_right_wheel"/>
    <axis xyz="0 1 0"/>
    <limit effort="100" velocity="10"/>
    <dynamics damping="1.0" friction="1.0"/>
  </joint>

  <link name="rear_right_wheel">
    <inertial>
      <mass value="5.0"/>
      <origin xyz="0 0 0" rpy="0 1.5707 1.5707"/>
      <inertia ixx="0.014" ixy="0" ixz="0"
               iyy="0.014" iyz="0"
               izz="0.025"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.5707 1.5707"/>
      <geometry><cylinder radius="0.1" length="0.05"/></geometry>
    </collision>
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5707 1.5707"/>
      <geometry><cylinder radius="0.1" length="0.05"/></geometry>
      <material name="green"/>
    </visual>
  </link>

  <!-- 2D LIDAR -->
  <joint type="fixed" name="scan_joint">
    <origin xyz="0.0 0 0.15" rpy="0 0 0"/>
    <child link="scan_link"/>
    <parent link="base_link"/>
  </joint>

  <link name="scan_link">
    <inertial>
      <mass value="1e-5"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="1e-6" ixy="0" ixz="0"
               iyy="1e-6" iyz="0"
               izz="1e-6"/>
    </inertial>

    <collision name="scan_collision">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.06 0.06"/>
      </geometry>
    </collision>

    <visual name="scan_link_visual">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.06 0.06"/>
      </geometry>
    </visual>
  </link>
  
  <!-- IMU -->
  <joint name="imu_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="imu_link"/>
  </joint>

  <link name="imu_link"/>
  
</robot>
